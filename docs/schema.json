    "paths": {
        "/ibge/api/v1/estados/": {
            "get": {
                "operationId": "ibge_api_v1_estados_list",
                "description": "Retorna todos os estados brasileiros com sigla, nome e região.",
                "summary": "Listar estados",
                "tags": [
                    "ibge"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/State"
                                    }
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/ibge/api/v1/estados/{sigla}/": {
            "get": {
                "operationId": "ibge_api_v1_estados_retrieve",
                "description": "Retorna os dados de um estado específico pela sigla (ex: SP, RJ).",
                "summary": "Detalhe do estado",
                "parameters": [
                    {
                        "in": "path",
                        "name": "sigla",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Sigla do estado (ex: SP)",
                        "required": true
                    }
                ],
                "tags": [
                    "ibge"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/State"
                                }
                            }
                        },
                        "description": ""
                    },
                    "404": {
                        "description": "No response body"
                    }
                }
            }
        },
