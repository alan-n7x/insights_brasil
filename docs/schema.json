    "components": {
        "schemas": {
            "MunicipalityDetail": {
                "type": "object",
                "properties": {
                    "codigo": {
                        "type": "integer"
                    },
                    "nome": {
                        "type": "string"
                    },
                    "estado": {
                        "$ref": "#/components/schemas/State"
                    },
                    "microrregiao_id": {
                        "type": "integer",
                        "nullable": true
                    },
                    "microrregiao_nome": {
                        "type": "string",
                        "nullable": true
                    },
                    "mesorregiao_id": {
                        "type": "integer",
                        "nullable": true
                    },
                    "mesorregiao_nome": {
                        "type": "string",
                        "nullable": true
                    },
                    "regiao_imediata_id": {
                        "type": "integer",
                        "nullable": true
                    },
                    "regiao_intermediaria_id": {
                        "type": "integer",
                        "nullable": true
                    }
                },
                "required": [
                    "codigo",
                    "estado",
                    "nome"
                ]
            },
            "MunicipalityItem": {
                "type": "object",
                "properties": {
                    "codigo": {
                        "type": "integer"
                    },
                    "nome": {
                        "type": "string"
                    },
                    "sigla": {
                        "type": "string",
                        "readOnly": true
                    },
                    "valor": {
                        "type": "number",
                        "format": "double"
                    }
                },
                "required": [
                    "codigo",
                    "nome",
                    "sigla",
                    "valor"
                ]
            },
            "MunicipalityList": {
                "type": "object",
                "properties": {
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MunicipalityItem"
                        }
                    }
                },
                "required": [
                    "items"
                ]
            },
            "State": {
                "type": "object",
                "properties": {
                    "sigla": {
                        "type": "string"
                    },
                    "nome": {
                        "type": "string"
                    },
                    "regiao": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "required": [
                    "nome",
                    "sigla"
                ]
            },
            "Summary": {
                "type": "object",
                "properties": {
                    "populacao": {
                        "type": "integer"
                    },
                    "pib": {
                        "type": "integer"
                    },
                    "pib_per_capita": {
                        "type": "number",
                        "format": "double"
                    }
                },
                "required": [
                    "pib",
                    "pib_per_capita",
                    "populacao"
                ]
            }
        },
        "securitySchemes": {
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            },
            "cookieAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "sessionid"
            }
        }
    }
